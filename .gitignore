/target
**/*.rs.bk

# IDE
.idea/
.vscode/

# OS
.DS_Store
Thumbs.db

# Editor swap files
*.swp
*.swo

# Архивы в корне — обычно исходники шрифтов / выгрузок, не для репо.
/*.zip
/*.tar
/*.tar.gz

# Локальные утилиты — бинарники >100MB не принимает GitHub.
# Скачать: https://www.gyan.dev/ffmpeg/builds/ (full build, 2022-09-15)
/utils/ffmpeg.exe

# Автосохранённая сессия — рабочий артефакт, не для репо.
*.lsession
last_session.db

# Оркестратор: стоп-файлы, файлы статуса и состояния сессии.
/scripts/.stop-*
/scripts/.jobstatus-*
/scripts/.session-*.json
/scripts/.coder-session-*.json
# Coders solo worklog: отчёт о наработках, ожидающих влития; чистится Claude после merge.
/scripts/coders-worklog.md
# Kilo debug-логи обмена (тайминг/детали троттлинга) — транзиентные.
/scripts/coder-debug-*.log
# Отчёты визуальной приёмки nano-omni; чистятся Claude после merge ветки.
/scripts/vision-reports/
/.jobstatus-*
__pycache__/

# Графические тесты: рабочие скрины (Edge-эталон, Lumen-захват, diff) — не коммитим.
# См. CLAUDE.md → «Графические тесты», правило №1.
/graphic_tests/screenshots/
/graphic_tests/debug/
# results/*.json коммитятся (история прогонов в git); HTML-отчёты — нет (ссылаются на gitignored PNG).
/graphic_tests/results/*.html

# Личная временная папка ассистента (скриншоты --screenshot, черновые артефакты).
# Всё рабочее держим в папке проекта, не в системном temp.
/.tmp/

# P2-wpt: MANIFEST.json + wptrunner's own mtime cache are regenerated by
# `wptrunner --manifest-update` from the vendored test tree
# (tests/wpt/run_smoke.py); `.ini` expectations that will live alongside them
# from S5 onward are NOT covered by these patterns.
/tests/wpt/metadata/MANIFEST.json
/tests/wpt/metadata/.cache/
